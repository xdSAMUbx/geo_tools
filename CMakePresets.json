{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "conda-linux",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_PREFIX_PATH": "$env{CONDA_PREFIX}",
        "CMAKE_LIBRARY_PATH": "$env{CONDA_PREFIX}/lib",
        "CMAKE_BUILD_RPATH": "$env{CONDA_PREFIX}/lib",
        "CMAKE_EXE_LINKER_FLAGS": "-L$env{CONDA_PREFIX}/lib"
      }
    },
    {
      "name": "linux-release",
      "displayName": "Linux (Conda) - Release",
      "inherits": "conda-linux",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "linux-release",
      "configurePreset": "linux-release",
      "jobs": 8
    }
  ]
}
